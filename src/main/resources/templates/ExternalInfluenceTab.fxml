<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Button?>
<VBox spacing="20" style="-fx-padding: 20;"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.andrewaleynik.reportdesigner.reportdesigner.controllers.ExternalInfluencesTabController"
      prefHeight="400.0" prefWidth="600.0">
    <TableView fx:id="externalInfluencesTableView" prefHeight="200">
    </TableView>
    <Button text="Добавить внешнее воздействие"
    onAction="#showAddExternalInfluenceForm"></Button>
</VBox>
