<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.andrewaleynik.reportdesigner.reportdesigner.controllers.ExternalInfluenceGroupFormController"
      spacing="20" style="-fx-padding: 20;">

    <Label text="Добавление группы внешних воздействий" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

    <GridPane hgap="10" vgap="10">
        <Label text="Название:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="nameField" GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="200"/>
    </GridPane>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button fx:id="okButton" text="OK" defaultButton="true" onAction="#handleOk"/>
        <Button text="Отмена" cancelButton="true" onAction="#handleCancel"/>
    </HBox>
</VBox>
