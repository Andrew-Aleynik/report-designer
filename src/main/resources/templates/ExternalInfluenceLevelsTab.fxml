<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<VBox spacing="20" style="-fx-padding: 20;"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.andrewaleynik.reportdesigner.reportdesigner.controllers.ExternalInfluenceLevelsTabController"
      prefHeight="400.0" prefWidth="600.0">
    <HBox>
        <Label text="Отобразить свойства для качества:"/>
        <ComboBox fx:id="qualitiesComboBox"/>
    </HBox>
    <Button text="Добавить интенсивнность воздействия" onAction="#showAddExternalInfluenceLevelForm"/>
    <TableView fx:id="externalInfluenceLevelsTableView" prefHeight="200">
    </TableView>
</VBox>