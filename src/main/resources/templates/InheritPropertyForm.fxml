<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.andrewaleynik.reportdesigner.reportdesigner.controllers.InheritPropertyFormController"
      spacing="20" style="-fx-padding: 20;">

    <Label text="Наследование потребительских свойств" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

    <GridPane hgap="10" vgap="10">
        <Label text="Наследование из свойств родительского потребительского качества: " GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <Label fx:id="parentQualityLabel" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Свойства:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
    </GridPane>
    <TableView fx:id="parentPropertiesTableView"/>
    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button fx:id="okButton" text="OK" defaultButton="true" onAction="#handleOk"/>
        <Button text="Отмена" cancelButton="true" onAction="#handleCancel"/>
    </HBox>
</VBox>
