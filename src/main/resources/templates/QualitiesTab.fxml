<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox spacing="20" style="-fx-padding: 20;"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.andrewaleynik.reportdesigner.reportdesigner.controllers.ElementQualitiesTabController">

    <!-- Панель управления -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Потребительские качества:"/>
        <ComboBox fx:id="elementQualitiesComboBox" prefWidth="200"/>
        <Button text="Добавить потребительское качество" onAction="#handleCreateElementQuality"/>
    </HBox>

    <!-- Редактирование качества -->
    <VBox spacing="15" style="-fx-border-color: #cccccc; -fx-border-width: 1; -fx-padding: 15;">
        <Label text="Выбор условий потребительского качества:" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>

        <GridPane hgap="10" vgap="10">
            <Label text="Связан с:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <Label fx:id="elementNameField" GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="200"/>

            <Label text="Код:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <TextField fx:id="codeField" GridPane.rowIndex="1" GridPane.columnIndex="1" prefWidth="200"/>

            <Label text="Срок службы:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <HBox spacing="5" GridPane.rowIndex="2" GridPane.columnIndex="1">
                <TextField fx:id="serviceLifeDaysField" prefWidth="80" promptText="дни"/>
                <Label text="дней"/>
            </HBox>

            <Label text="Граничное условие:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
            <TextField fx:id="satisfyingCostField" GridPane.rowIndex="3" GridPane.columnIndex="1" prefWidth="200" promptText="0.00"/>

            <Label text="Фактическая стоимость:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
            <TextField fx:id="actualCostField" GridPane.rowIndex="4" GridPane.columnIndex="1" prefWidth="200" promptText="0.00"/>
        </GridPane>

        <!-- Свойства качества -->
        <VBox spacing="10">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Потребительские свойства" style="-fx-font-weight: bold;"/>
                <Button text="Добавить свойство" onAction="#showAddPropertyForm"/>
            </HBox>

            <TableView fx:id="propertiesTableView" prefHeight="200">
            </TableView>
        </VBox>

        <!-- Кнопки управления -->
        <HBox spacing="10" alignment="CENTER_RIGHT">
            <Button fx:id="saveButton" text="Сохранить" defaultButton="true" onAction="#handleUpdateQuality"/>
            <Button fx:id="deleteButton" text="Удалить" style="-fx-text-fill: red;" onAction="#handleDeleteQuality"/>
        </HBox>
    </VBox>
</VBox>