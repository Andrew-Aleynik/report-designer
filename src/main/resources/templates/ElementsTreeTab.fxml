<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TreeView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<VBox spacing="10"
      style="-fx-padding: 10;"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.andrewaleynik.reportdesigner.reportdesigner.controllers.ElementsTreeTabController">
    <!-- Панель управления -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Корневые элементы:"/>
        <ComboBox fx:id="rootElementsComboBox" prefWidth="200"/>
        <Button text="Добавить корневой элемент" onAction="#showAddRootElementForm"/>
    </HBox>

    <!-- Дерево элементов -->
    <TreeView fx:id="elementsTreeView" VBox.vgrow="ALWAYS">
    </TreeView>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button fx:id="exportToPdf" text="Выгрузить в PDF" defaultButton="true" onAction="#showPreviewExportToPdf"/>
    </HBox>
</VBox>
