<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>
<?import com.andrewaleynik.reportdesigner.reportdesigner.components.buttons.SubgroupAddButton?>
<VBox xmlns="http://javafx.com/javafx/11.0.1"
      stylesheets="@../styles/group-component.css">

    <!-- Заголовок с кнопкой свертывания -->
    <HBox styleClass="title-container" spacing="5">
        <Label styleClass="title-label" text="Группа матриц"/>
        <Button styleClass="collapse-button" text="−"/>
    </HBox>

    <!-- Основное содержимое -->
    <Pane styleClass="collapsible-container">
        <Rectangle styleClass="content-border"/>

        <VBox styleClass="inner-content"
              spacing="10"
              alignment="CENTER">
            <SubgroupAddButton styleClass="content-button" text="Кнопка внутри элемента"/>
        </VBox>
    </Pane>
</VBox>