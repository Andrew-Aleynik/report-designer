<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<VBox spacing="10"
      style="-fx-padding: 10;"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.andrewaleynik.reportdesigner.reportdesigner.controllers.ElementQualitiesTabController">
    <!-- Панель управления -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Качества:"/>
        <ComboBox fx:id="elementQualitiesComboBox" prefWidth="200"/>
        <Button text="Добавить качество" onAction="#handleCreateElementQuality"/>
    </HBox>

    <!-- Редактирование качества -->

</VBox>
