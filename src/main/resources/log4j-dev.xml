<Configuration status="WARN">
    <Appenders>
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="%style{%d{HH:mm:ss.SSS}}{cyan} [%t] %highlight{%-5level} %logger{36} - %msg%n"/>
        </Console>
    </Appenders>

    <Loggers>
        <Logger name="com.andrewaleynik.reportdesigner.reportdesigner.util" level="INFO">
            <AppenderRef ref="Console"/>
        </Logger>
        <Logger name="com.andrewaleynik.reportdesigner.reportdesigner" level="DEBUG">

        </Logger>
        <Root level="INFO">
            <AppenderRef ref="Console"/>
        </Root>
    </Loggers>
</Configuration>